{
  "name": "agent-tooling",
  "version": "0.10.2",
  "description": "Pi coding agent extensions and skills",
  "pi": {
    "skills": [
      "./skills"
    ],
    "extensions": [
      "./pi-extensions"
    ]
  },
  "dependencies": {
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.73.1",
    "@types/node": "^25.6.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "verify": "npm run typecheck && npm test"
  }
}
