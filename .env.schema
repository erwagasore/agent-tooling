# OANDA forex broker API credentials
# Sign up at https://www.oanda.com/apply/ (practice account is free)
# Generate token at Account → Manage API Access

# @required
OANDA_ACCOUNT_ID=op("op://rwagasore/OANDA API/OANDA_ACCOUNT_ID")

# @required
OANDA_API_KEY=op("op://rwagasore/OANDA API/OANDA_API_KEY")

# FRED (Federal Reserve Economic Data) API key
FRED_API_KEY=op("op://rwagasore/FRED API/API_KEY")
